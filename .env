# =============================================
# AgriSmart Backend - Environment Variables
# =============================================

# Server
PORT=8000
NODE_ENV=development

# MongoDB Connection
# Option 1: Local MongoDB (install MongoDB Community from https://www.mongodb.com/try/download/community)
MONGO_URI=mongodb://localhost:27017/agrismart

# Option 2: MongoDB Atlas (free cloud - replace with your connection string)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/agrismart

# Frontend URL (for CORS)
FRONTEND_URL=http://127.0.0.1:5500
